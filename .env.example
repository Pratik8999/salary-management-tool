# Copy this file to .env and adjust as needed.
# .env is gitignored.

# --- PostgreSQL ---
POSTGRES_USER=salary
POSTGRES_PASSWORD=salary
POSTGRES_DB=salary_management
POSTGRES_PORT=5432

# --- Backend ---
# Inside compose the backend reaches postgres via the service hostname `db`.
DATABASE_URL=postgresql+psycopg://salary:salary@db:5432/salary_management
BACKEND_PORT=8000

# --- Frontend ---
FRONTEND_PORT=5173
# Browser hits the backend on the host port, not the compose hostname.
VITE_API_BASE_URL=http://localhost:8000
