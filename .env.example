# Copy this file to your own .env and adjust as needed.

# PostgreSQL
POSTGRES_USER=pratik
POSTGRES_PASSWORD=root123
POSTGRES_DB=salary_management
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql+psycopg://pratik:root123@db:5432/salary_management
BACKEND_PORT=8000

# Test DB — used by pytest when running from the host
TEST_DATABASE_URL=postgresql+psycopg://pratik:root123@localhost:5432/salary_management_test

# JWT auth — generate a long random string for non-dev environments
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Employee documents
# STORAGE_ROOT is overridden to /data/documents inside compose; the bind mount
# surfaces uploaded files at backend/storage/documents on the host. For host-
# only runs (pytest, uvicorn outside docker), the path is relative to backend/.
STORAGE_ROOT=storage/documents
DOCUMENT_MAX_BYTES=5242880  # 5 MB (1 MB = 1048576, 1 GB = 1073741824)

# Frontend
FRONTEND_PORT=5173
# Browser hits the backend on the host port, not the compose hostname.
VITE_API_BASE_URL=http://localhost:8000
