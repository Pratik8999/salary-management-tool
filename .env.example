# Copy this file to your own .env and adjust as needed.

# PostgreSQL
POSTGRES_USER=salary
POSTGRES_PASSWORD=salary
POSTGRES_DB=salary_management
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql+psycopg://salary:salary@db:5432/salary_management
BACKEND_PORT=8000

# Test DB — used by pytest when running from the host
TEST_DATABASE_URL=postgresql+psycopg://salary:salary@localhost:5432/salary_management_test

# JWT auth — generate a long random string for non-dev environments
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend
FRONTEND_PORT=5173
